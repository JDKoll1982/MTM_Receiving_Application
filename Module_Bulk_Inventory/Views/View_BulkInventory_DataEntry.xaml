<UserControl
    x:Class="MTM_Receiving_Application.Module_Bulk_Inventory.Views.View_BulkInventory_DataEntry"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:MTM_Receiving_Application.Module_Core.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MTM_Receiving_Application.Module_Bulk_Inventory.Models"
    mc:Ignorable="d"
    Loaded="UserControl_Loaded"
    KeyDown="UserControl_KeyDown">

    <UserControl.Resources>
        <converters:Converter_InverseBool x:Key="InverseBoolConverter" />
        <converters:Converter_DecimalToDouble x:Key="DecimalToDoubleConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="20" RowSpacing="12">

        <!-- ── Header / Toolbar ─────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
            <TextBlock
                Text="Bulk Inventory Transactions"
                Style="{StaticResource TitleTextBlockStyle}"
                VerticalAlignment="Center" />

            <Button
                Content="＋ Add Row"
                Command="{x:Bind ViewModel.AddRowCommand}"
                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                ToolTipService.ToolTip="Add a new blank row (Ctrl+N)" />

            <Button
                Content="✕ Clear All"
                Command="{x:Bind ViewModel.ClearAllCommand}"
                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                ToolTipService.ToolTip="Remove all rows" />

            <Button
                Content="✔ Validate All"
                Command="{x:Bind ViewModel.ValidateAllCommand}"
                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                ToolTipService.ToolTip="Validate all rows before pushing" />

            <Button
                Content="▶ Push Batch"
                Command="{x:Bind ViewModel.PushBatchCommand}"
                Style="{StaticResource AccentButtonStyle}"
                ToolTipService.ToolTip="Send all valid rows to Infor Visual" />
        </StackPanel>

        <!-- ── Interrupted-batch warning banner ─────────────────────────── -->
        <InfoBar
            Grid.Row="1"
            Title="Interrupted batch detected"
            Message="Some rows from a previous session are still pending. Review and re-push or remove them."
            Severity="Warning"
            IsOpen="{x:Bind ViewModel.HasInterruptedRows, Mode=OneWay}"
            IsClosable="False" />

        <!-- ── Data Grid ────────────────────────────────────────────────── -->
        <ListView
            Grid.Row="2"
            ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}"
            SelectionMode="None">

            <ListView.Header>
                <Grid ColumnDefinitions="130,120,125,90,125,125,90,*,36" Padding="12,4">
                    <TextBlock Grid.Column="0" Text="Part ID" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock Grid.Column="1" Text="Type" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock Grid.Column="2" Text="From Location" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock Grid.Column="3" Text="Quantity" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock Grid.Column="4" Text="To Warehouse" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock Grid.Column="5" Text="To Location" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock Grid.Column="6" Text="Status" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock Grid.Column="7" Text="Validation" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock Grid.Column="8" Text="" />
                </Grid>
            </ListView.Header>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Model_BulkInventoryTransaction">
                    <Grid ColumnDefinitions="130,120,125,90,125,125,90,*,36"
                          Padding="12,4" RowSpacing="2">

                        <!-- Part ID with fuzzy-search button -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                            <TextBox
                                Text="{x:Bind PartId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="Part ID"
                                MinWidth="90" />
                        </StackPanel>

                        <!-- Transaction type -->
                        <ComboBox Grid.Column="1"
                                  SelectedIndex="{x:Bind TransactionTypeIndex, Mode=TwoWay}"
                                  MinWidth="110">
                            <x:String>Transfer</x:String>
                            <x:String>NewTransaction</x:String>
                        </ComboBox>

                        <!-- From Location -->
                        <TextBox Grid.Column="2"
                                 Text="{x:Bind FromLocation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="From location" />

                        <!-- Quantity -->
                        <NumberBox Grid.Column="3"
                                   Value="{x:Bind Quantity, Mode=TwoWay,
                                          Converter={StaticResource DecimalToDoubleConverter}}"
                                   Minimum="0.001"
                                   SmallChange="1"
                                   SpinButtonPlacementMode="Compact" />

                        <!-- To Warehouse -->
                        <TextBox Grid.Column="4"
                                 Text="{x:Bind ToWarehouse, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="To warehouse" />

                        <!-- To Location -->
                        <TextBox Grid.Column="5"
                                 Text="{x:Bind ToLocation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="To location" />

                        <!-- Status badge -->
                        <TextBlock Grid.Column="6"
                                   Text="{x:Bind Status, Mode=OneWay}"
                                   VerticalAlignment="Center" />

                        <!-- Validation message -->
                        <TextBlock Grid.Column="7"
                                   Text="{x:Bind ValidationMessage, Mode=OneWay}"
                                   Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />

                        <!-- Delete row button -->
                        <Button Grid.Column="8"
                                Content="✕"
                                Tag="{x:Bind}"
                                Click="DeleteRowButton_Click"
                                ToolTipService.ToolTip="Remove this row"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="4" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- ── Legend strip ─────────────────────────────────────────────── -->
        <Grid Grid.Row="3" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Status colour legend -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemFillColorSuccessBrush}" Text="■ Success" />
                <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Text="■ Failed" />
                <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemFillColorCautionBrush}" Text="■ Warning" />
                <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemFillColorNeutralBrush}" Text="■ Skipped / Consolidated" />
            </StackPanel>

            <!-- Keyboard shortcut legend -->
            <TextBlock Grid.Column="1"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="F5 = Push Batch   |   F6 = Skip Row   |   Escape = Clear"
                       VerticalAlignment="Center" />
        </Grid>

    </Grid>
</UserControl>
