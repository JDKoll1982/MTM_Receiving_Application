<UserControl
    x:Class="MTM_Receiving_Application.Module_Bulk_Inventory.Views.View_BulkInventory_DataEntry"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:converters="using:MTM_Receiving_Application.Module_Core.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="UserControl_Loaded"
    KeyDown="UserControl_KeyDown"
>
    <UserControl.Resources>
        <converters:Converter_InverseBool x:Key="InverseBoolConverter" />
        <converters:Converter_DecimalToDouble x:Key="DecimalToDoubleConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="16" RowSpacing="12">
        <!-- ============================================================ Row 0: Toolbar -->
        <Grid Grid.Row="0" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel
                Grid.Column="0"
                Orientation="Horizontal"
                Spacing="12"
                VerticalAlignment="Center"
            >
                <TextBlock
                    Text="Bulk Inventory Transactions"
                    Style="{StaticResource TitleTextBlockStyle}"
                    VerticalAlignment="Center"
                />

                <!-- Separator -->
                <Rectangle
                    Width="1"
                    Height="24"
                    Fill="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    Margin="4,0"
                />

                <Button
                    Command="{x:Bind ViewModel.AddRowCommand}"
                    IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                    ToolTipService.ToolTip="Add a new blank row"
                >
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" />
                        <TextBlock Text="Add Row" />
                    </StackPanel>
                </Button>

                <Button
                    Command="{x:Bind ViewModel.ClearAllCommand}"
                    IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                    ToolTipService.ToolTip="Remove all rows"
                >
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74D;" />
                        <TextBlock Text="Clear All" />
                    </StackPanel>
                </Button>

                <!-- Separator -->
                <Rectangle
                    Width="1"
                    Height="24"
                    Fill="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    Margin="4,0"
                />

                <Button
                    Command="{x:Bind ViewModel.PushBatchCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    ToolTipService.ToolTip="Send all valid rows to Infor Visual (F5)"
                >
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8AB;" />
                        <TextBlock Text="Push Batch" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ============================================================ Row 1: Interrupted-batch warning -->
        <InfoBar
            Grid.Row="1"
            Title="Interrupted batch detected"
            Message="Some rows from a previous session are still pending. Review and re-push or remove them."
            Severity="Warning"
            IsOpen="{x:Bind ViewModel.HasInterruptedRows, Mode=OneWay}"
            IsClosable="False"
        />

        <!-- ============================================================ Row 2: Data Grid -->
        <controls:DataGrid
            Grid.Row="2"
            x:Name="BulkInventoryDataGrid"
            ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}"
            AutoGenerateColumns="False"
            IsReadOnly="False"
            CanUserSortColumns="False"
            GridLinesVisibility="All"
            HeadersVisibility="Column"
            SelectionMode="Single"
            CellEditEnded="BulkInventoryDataGrid_CellEditEnded"
        >
            <controls:DataGrid.Columns>
                <!-- Part ID -->
                <controls:DataGridTemplateColumn Header="Part ID" Tag="PartId" Width="150">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                Text="{Binding PartId}"
                                VerticalAlignment="Center"
                                Padding="12,0"
                            />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                    <controls:DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox
                                Text="{Binding PartId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                BorderThickness="0"
                                VerticalAlignment="Stretch"
                            />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellEditingTemplate>
                </controls:DataGridTemplateColumn>

                <!-- Transaction Type -->
                <controls:DataGridTemplateColumn Header="Type" Tag="TransactionType" Width="130">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                Text="{Binding TransactionType}"
                                VerticalAlignment="Center"
                                Padding="12,0"
                            />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                    <controls:DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox
                                SelectedIndex="{Binding TransactionTypeIndex, Mode=TwoWay}"
                                BorderThickness="0"
                                VerticalAlignment="Stretch"
                                HorizontalAlignment="Stretch"
                            >
                                <x:String>Transfer</x:String>
                                <x:String>NewTransaction</x:String>
                            </ComboBox>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellEditingTemplate>
                </controls:DataGridTemplateColumn>

                <!-- From Location -->
                <controls:DataGridTemplateColumn
                    Header="From Location"
                    Tag="FromLocation"
                    Width="140"
                >
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                Text="{Binding FromLocation}"
                                VerticalAlignment="Center"
                                Padding="12,0"
                            />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                    <controls:DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox
                                Text="{Binding FromLocation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                BorderThickness="0"
                                VerticalAlignment="Stretch"
                            />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellEditingTemplate>
                </controls:DataGridTemplateColumn>

                <!-- Quantity -->
                <controls:DataGridTemplateColumn Header="Quantity" Tag="Quantity" Width="110">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                Text="{Binding Quantity}"
                                VerticalAlignment="Center"
                                Padding="12,0"
                            />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                    <controls:DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <NumberBox
                                Value="{Binding Quantity, Mode=TwoWay, Converter={StaticResource DecimalToDoubleConverter}}"
                                Minimum="0.001"
                                SmallChange="1"
                                SpinButtonPlacementMode="Compact"
                                BorderThickness="0"
                                VerticalAlignment="Stretch"
                            />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellEditingTemplate>
                </controls:DataGridTemplateColumn>

                <!-- To Warehouse -->
                <controls:DataGridTemplateColumn
                    Header="To Warehouse"
                    Tag="ToWarehouse"
                    Width="130"
                >
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                Text="{Binding ToWarehouse}"
                                VerticalAlignment="Center"
                                Padding="12,0"
                            />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                    <controls:DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox
                                Text="{Binding ToWarehouse, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                BorderThickness="0"
                                VerticalAlignment="Stretch"
                            />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellEditingTemplate>
                </controls:DataGridTemplateColumn>

                <!-- To Location -->
                <controls:DataGridTemplateColumn Header="To Location" Tag="ToLocation" Width="140">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                Text="{Binding ToLocation}"
                                VerticalAlignment="Center"
                                Padding="12,0"
                            />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                    <controls:DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox
                                Text="{Binding ToLocation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                BorderThickness="0"
                                VerticalAlignment="Stretch"
                            />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellEditingTemplate>
                </controls:DataGridTemplateColumn>

                <!-- Status (read-only) -->
                <controls:DataGridTextColumn
                    Header="Status"
                    Tag="Status"
                    Binding="{Binding Status}"
                    IsReadOnly="True"
                    Width="Auto"
                />

                <!-- Validation message -->
                <controls:DataGridTemplateColumn Header="Validation" Tag="Validation" Width="*">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                Text="{Binding ValidationMessage}"
                                Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                TextWrapping="Wrap"
                                VerticalAlignment="Center"
                                Padding="12,0"
                            />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

                <!-- Delete row -->
                <controls:DataGridTemplateColumn Header="" Width="44" CanUserResize="False">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button
                                Content="&#x2715;"
                                Tag="{Binding}"
                                Click="DeleteRowButton_Click"
                                ToolTipService.ToolTip="Remove this row"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                            />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <!-- ============================================================ Row 3: Legend strip -->
        <Grid Grid.Row="3" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                <TextBlock
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                    Text="&#x25A0; Success"
                />
                <TextBlock
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    Text="&#x25A0; Failed"
                />
                <TextBlock
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource SystemFillColorCautionBrush}"
                    Text="&#x25A0; Validation Warning"
                />
                <TextBlock
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource SystemFillColorNeutralBrush}"
                    Text="&#x25A0; Skipped / Consolidated"
                />
            </StackPanel>

            <TextBlock
                Grid.Column="1"
                Style="{StaticResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="F5 = Push Batch   |   Escape = Clear All"
                VerticalAlignment="Center"
            />
        </Grid>

        <!-- ============================================================ IsBusy Overlay -->
        <Grid Grid.RowSpan="4" Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}">
            <Rectangle Fill="{ThemeResource ApplicationPageBackgroundThemeBrush}" Opacity="0.7" />
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                <ProgressRing
                    IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                    Width="48"
                    Height="48"
                />
                <TextBlock
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    HorizontalAlignment="Center"
                    FontSize="14"
                />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
