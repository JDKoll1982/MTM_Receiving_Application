<Page
    x:Class="MTM_Receiving_Application.Module_Bulk_Inventory.Views.View_BulkInventory_Push"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="900"
    d:DesignHeight="600"
>
    <!--
        Full-screen dark overlay shown while Visual UI Automation is running.
        ViewModel: ViewModel_BulkInventory_Push (set via ViewModel property after DI resolution)
        Keyboard shortcuts handled in code-behind:
            F6  → skip current row
            Esc → cancel batch
    -->

    <Grid Background="{ThemeResource SystemFillColorBackgroundBrush}">
        <Grid
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            MinWidth="580"
            Padding="40"
            RowSpacing="24"
        >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock
                Grid.Row="0"
                Text="Bulk Inventory Push"
                Style="{StaticResource TitleTextBlockStyle}"
                HorizontalAlignment="Center"
            />

            <!-- Current row status -->
            <TextBlock
                Grid.Row="1"
                Text="{x:Bind ViewModel.OverlayStatusMessage, Mode=OneWay}"
                Style="{StaticResource BodyTextBlockStyle}"
                HorizontalAlignment="Center"
                TextWrapping="Wrap"
                MaxWidth="500"
            />

            <!-- Progress ring (visible while automation is running) -->
            <ProgressBar
                Grid.Row="2"
                Minimum="0"
                Maximum="{x:Bind ViewModel.TotalCount, Mode=OneWay}"
                Value="{x:Bind ViewModel.ProcessedCount, Mode=OneWay}"
                IsIndeterminate="{x:Bind ViewModel.IsAutomationRunning, Mode=OneWay}"
                HorizontalAlignment="Stretch"
                MinWidth="500"
            />

            <!-- Row counter -->
            <StackPanel
                Grid.Row="3"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="8"
            >
                <TextBlock Text="{x:Bind ViewModel.ProcessedCount, Mode=OneWay}" />
                <TextBlock Text="/" />
                <TextBlock Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}" />
                <TextBlock Text="rows" />
            </StackPanel>

            <!-- Action buttons -->
            <StackPanel
                Grid.Row="4"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="12"
            >
                <Button
                    Content="Skip Row (F6)"
                    Click="SkipRow_Click"
                    IsEnabled="{x:Bind ViewModel.IsAutomationRunning, Mode=OneWay}"
                />

                <Button
                    Content="Cancel (Esc)"
                    Command="{x:Bind ViewModel.CancelPushCommand}"
                    IsEnabled="{x:Bind ViewModel.IsAutomationRunning, Mode=OneWay}"
                />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
