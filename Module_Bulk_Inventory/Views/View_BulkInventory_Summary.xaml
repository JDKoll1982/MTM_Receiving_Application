<Page
    x:Class="MTM_Receiving_Application.Module_Bulk_Inventory.Views.View_BulkInventory_Summary"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:MTM_Receiving_Application.Module_Core.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MTM_Receiving_Application.Module_Bulk_Inventory.Models"
    mc:Ignorable="d"
    d:DesignWidth="900"
    d:DesignHeight="700"
>
    <Page.Resources>
        <converters:Converter_IntToVisibility x:Key="CountToVisibilityConverter" />
        <converters:Converter_InverseBool x:Key="InverseBoolConverter" />
        <converters:Converter_InfoBarSeverity x:Key="InfoBarSeverityConverter" />
    </Page.Resources>

    <!--
        Post-automation summary screen.
        Shows Success / Failed / Skipped badge counts, lists failed rows for re-push, and
        routes the user back to DataEntry via the Done button.
        ViewModel: ViewModel_BulkInventory_Summary (set via code-behind)
    -->

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="32" Spacing="24">
            <!-- Title -->
            <TextBlock Text="Batch Complete" Style="{StaticResource TitleTextBlockStyle}" />

            <!-- Badge row -->
            <StackPanel Orientation="Horizontal" Spacing="16">
                <!-- Success badge -->
                <Border
                    Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                    CornerRadius="8"
                    Padding="16,12"
                >
                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <TextBlock
                            Text="{x:Bind ViewModel.SuccessCount, Mode=OneWay}"
                            Style="{StaticResource TitleLargeTextBlockStyle}"
                            HorizontalAlignment="Center"
                        />
                        <TextBlock
                            Text="Success"
                            Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                        />
                    </StackPanel>
                </Border>

                <!-- Failed badge -->
                <Border
                    Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                    CornerRadius="8"
                    Padding="16,12"
                >
                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <TextBlock
                            Text="{x:Bind ViewModel.FailedCount, Mode=OneWay}"
                            Style="{StaticResource TitleLargeTextBlockStyle}"
                            HorizontalAlignment="Center"
                        />
                        <TextBlock
                            Text="Failed"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        />
                    </StackPanel>
                </Border>

                <!-- Skipped badge -->
                <Border
                    Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                    CornerRadius="8"
                    Padding="16,12"
                >
                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <TextBlock
                            Text="{x:Bind ViewModel.SkippedCount, Mode=OneWay}"
                            Style="{StaticResource TitleLargeTextBlockStyle}"
                            HorizontalAlignment="Center"
                        />
                        <TextBlock Text="Skipped" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Failed rows list (only visible when there are failures) -->
            <StackPanel
                Spacing="12"
                Visibility="{x:Bind ViewModel.FailedRows.Count, Mode=OneWay,
                                     Converter={StaticResource CountToVisibilityConverter}}"
            >
                <TextBlock
                    Text="Failed rows — select to re-push:"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                />

                <ListView
                    ItemsSource="{x:Bind ViewModel.FailedRows, Mode=OneWay}"
                    SelectionMode="None"
                >
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Model_BulkInventoryTransaction">
                            <Grid ColumnSpacing="12" Padding="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2*" />
                                </Grid.ColumnDefinitions>

                                <CheckBox
                                    Grid.Column="0"
                                    IsChecked="{x:Bind IsSelectedForRepush, Mode=TwoWay}"
                                    VerticalAlignment="Center"
                                />

                                <TextBlock
                                    Grid.Column="1"
                                    Text="{x:Bind PartId}"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                />

                                <TextBlock
                                    Grid.Column="2"
                                    Text="{x:Bind ToLocation}"
                                    VerticalAlignment="Center"
                                />

                                <TextBlock
                                    Grid.Column="3"
                                    Text="{x:Bind ErrorMessage}"
                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                    VerticalAlignment="Center"
                                    TextWrapping="Wrap"
                                />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Button
                    Content="Re-push Selected"
                    Command="{x:Bind ViewModel.RePushSelectedCommand}"
                    IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay,
                                    Converter={StaticResource InverseBoolConverter}}"
                />
            </StackPanel>

            <!-- InfoBar for status messages -->
            <InfoBar
                x:Name="SummaryInfoBar"
                IsOpen="{x:Bind ViewModel.IsStatusOpen, Mode=OneWay}"
                Severity="{x:Bind ViewModel.StatusSeverity, Mode=OneWay,
                                Converter={StaticResource InfoBarSeverityConverter}}"
                Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                IsClosable="True"
            />

            <!-- Done -->
            <Button
                Content="Done — Start New Batch"
                Command="{x:Bind ViewModel.DoneCommand}"
                Style="{StaticResource AccentButtonStyle}"
            />
        </StackPanel>
    </ScrollViewer>
</Page>
