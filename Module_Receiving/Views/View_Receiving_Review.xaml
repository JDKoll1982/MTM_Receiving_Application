<UserControl
    x:Class="MTM_Receiving_Application.Module_Receiving.Views.View_Receiving_Review"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:converters="using:MTM_Receiving_Application.Module_Core.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    HorizontalContentAlignment="Stretch"
    VerticalContentAlignment="Stretch"
    mc:Ignorable="d"
>
    <UserControl.Resources>
        <converters:Converter_BooleanToVisibility x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Padding="24" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Content Section with View Toggle  -->
        <Grid Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <!--  Single Entry View  -->
            <Grid
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Visibility="{x:Bind ViewModel.IsSingleView, Mode=OneWay}"
            >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Entry Counter  -->
                <Border
                    Grid.Row="0"
                    Padding="12,6"
                    HorizontalAlignment="Stretch"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    CornerRadius="8,8,0,0"
                >
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="16" Foreground="White" Glyph="&#xE8FD;" />
                        <TextBlock
                            Foreground="White"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                        >
                            <Run Text="{x:Bind ViewModel.ReviewEntryLabelText, Mode=OneWay}" />
                            <Run
                                FontWeight="Bold"
                                Text="{x:Bind ViewModel.DisplayIndex, Mode=OneWay}"
                            />
                            <Run Text="{x:Bind ViewModel.ReviewOfLabelText, Mode=OneWay}" />
                            <Run
                                FontWeight="Bold"
                                Text="{x:Bind ViewModel.Loads.Count, Mode=OneWay}"
                            />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!--  Single Entry Form  -->
                <Grid Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Border
                        Padding="20"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1,0,1,1"
                        CornerRadius="0,0,8,8"
                    >
                        <controls:UniformGrid
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            ColumnSpacing="8"
                            Columns="3"
                            RowSpacing="8"
                        >
                            <!--  PO Number  -->

                            <controls:UniformGrid
                                Margin="0,0,8,0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Columns="1"
                                Rows="2"
                            >
                                <Border
                                    Grid.Row="0"
                                    Padding="12,6"
                                    HorizontalAlignment="Stretch"
                                    Background="{ThemeResource CardStrokeColorDefault}"
                                    CornerRadius="8,8,0,0"
                                >
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon
                                            FontSize="14"
                                            Foreground="{ThemeResource TextFillColorPrimary}"
                                            Glyph="&#xE8A5;"
                                        />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorPrimary}"
                                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                                            Text="{x:Bind ViewModel.ReviewPurchaseOrderNumberText, Mode=OneWay}"
                                        />
                                    </StackPanel>
                                </Border>
                                <TextBox
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Background="{ThemeResource ControlFillColorDisabledBrush}"
                                    CornerRadius="0,0,8,8"
                                    IsHitTestVisible="False"
                                    IsReadOnly="True"
                                    Text="{x:Bind ViewModel.CurrentEntry.PoNumber, Mode=OneWay}"
                                />
                            </controls:UniformGrid>

                            <!--  Part ID  -->

                            <controls:UniformGrid
                                Margin="0,0,8,0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Columns="1"
                                Rows="2"
                            >
                                <Border
                                    Grid.Row="0"
                                    Padding="12,6"
                                    HorizontalAlignment="Stretch"
                                    Background="{ThemeResource CardStrokeColorDefault}"
                                    CornerRadius="8,8,0,0"
                                >
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon
                                            FontSize="14"
                                            Foreground="{ThemeResource TextFillColorPrimary}"
                                            Glyph="&#xE8B7;"
                                        />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorPrimary}"
                                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                                            Text="{x:Bind ViewModel.ReviewPartIdText, Mode=OneWay}"
                                        />
                                    </StackPanel>
                                </Border>
                                <TextBox
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Background="{ThemeResource ControlFillColorDisabledBrush}"
                                    CornerRadius="0,0,8,8"
                                    IsHitTestVisible="False"
                                    IsReadOnly="True"
                                    Text="{x:Bind ViewModel.CurrentEntry.PartID, Mode=OneWay}"
                                />
                            </controls:UniformGrid>

                            <!--  Weight/Quantity  -->

                            <controls:UniformGrid
                                Margin="0,0,8,0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Columns="1"
                                Rows="2"
                            >
                                <Border
                                    Grid.Row="0"
                                    Padding="12,6"
                                    HorizontalAlignment="Stretch"
                                    Background="{ThemeResource CardStrokeColorDefault}"
                                    CornerRadius="8,8,0,0"
                                >
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon
                                            FontSize="14"
                                            Foreground="{ThemeResource TextFillColorPrimary}"
                                            Glyph="&#xEA8B;"
                                        />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorPrimary}"
                                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                                            Text="{x:Bind ViewModel.ReviewWeightQuantityText, Mode=OneWay}"
                                        />
                                    </StackPanel>
                                </Border>
                                <TextBox
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Background="{ThemeResource ControlFillColorDisabledBrush}"
                                    CornerRadius="0,0,8,8"
                                    IsHitTestVisible="False"
                                    IsReadOnly="True"
                                    Text="{x:Bind ViewModel.CurrentEntry.WeightQuantity, Mode=OneWay}"
                                />
                            </controls:UniformGrid>

                            <!--  Heat/Lot Number  -->

                            <controls:UniformGrid
                                Margin="0,0,8,0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Columns="1"
                                Rows="2"
                            >
                                <Border
                                    Grid.Row="0"
                                    Padding="12,6"
                                    HorizontalAlignment="Stretch"
                                    Background="{ThemeResource CardStrokeColorDefault}"
                                    CornerRadius="8,8,0,0"
                                >
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon
                                            FontSize="14"
                                            Foreground="{ThemeResource TextFillColorPrimary}"
                                            Glyph="&#xE8B4;"
                                        />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorPrimary}"
                                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                                            Text="{x:Bind ViewModel.ReviewHeatLotNumberText, Mode=OneWay}"
                                        />
                                    </StackPanel>
                                </Border>
                                <TextBox
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Background="{ThemeResource ControlFillColorDisabledBrush}"
                                    CornerRadius="0,0,8,8"
                                    IsHitTestVisible="False"
                                    IsReadOnly="True"
                                    Text="{x:Bind ViewModel.CurrentEntry.HeatLotNumber, Mode=OneWay}"
                                />
                            </controls:UniformGrid>

                            <!--  Location  -->

                            <controls:UniformGrid
                                Margin="0,0,8,0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Columns="1"
                                Rows="2"
                            >
                                <Border
                                    Grid.Row="0"
                                    Padding="12,6"
                                    HorizontalAlignment="Stretch"
                                    Background="{ThemeResource CardStrokeColorDefault}"
                                    CornerRadius="8,8,0,0"
                                >
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon
                                            FontSize="14"
                                            Foreground="{ThemeResource TextFillColorPrimary}"
                                            Glyph="&#xE707;"
                                        />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorPrimary}"
                                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                                            Text="{x:Bind ViewModel.ReviewLocationText, Mode=OneWay}"
                                        />
                                    </StackPanel>
                                </Border>
                                <TextBox
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Background="{ThemeResource ControlFillColorDisabledBrush}"
                                    CornerRadius="0,0,8,8"
                                    IsHitTestVisible="False"
                                    IsReadOnly="True"
                                    Text="{x:Bind ViewModel.CurrentEntry.InitialLocation, Mode=OneWay}"
                                />
                            </controls:UniformGrid>

                            <!--  Packages Per Load  -->

                            <controls:UniformGrid
                                Margin="0,0,8,0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Columns="1"
                                Rows="2"
                            >
                                <Border
                                    Grid.Row="0"
                                    Padding="12,6"
                                    HorizontalAlignment="Stretch"
                                    Background="{ThemeResource CardStrokeColorDefault}"
                                    CornerRadius="8,8,0,0"
                                >
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon
                                            FontSize="14"
                                            Foreground="{ThemeResource TextFillColorPrimary}"
                                            Glyph="&#xE7B8;"
                                        />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorPrimary}"
                                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                                            Text="{x:Bind ViewModel.ReviewPackagesPerLoadText, Mode=OneWay}"
                                        />
                                    </StackPanel>
                                </Border>
                                <TextBox
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Background="{ThemeResource ControlFillColorDisabledBrush}"
                                    CornerRadius="0,0,8,8"
                                    IsHitTestVisible="False"
                                    IsReadOnly="True"
                                    Text="{x:Bind ViewModel.CurrentEntry.PackagesPerLoad, Mode=OneWay}"
                                />
                            </controls:UniformGrid>

                            <!--  Package Type  -->

                            <controls:UniformGrid
                                Margin="0,0,8,0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Columns="1"
                                Rows="2"
                            >
                                <Border
                                    Grid.Row="0"
                                    Padding="12,6"
                                    HorizontalAlignment="Stretch"
                                    Background="{ThemeResource CardStrokeColorDefault}"
                                    CornerRadius="8,8,0,0"
                                >
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon
                                            FontSize="14"
                                            Foreground="{ThemeResource TextFillColorPrimary}"
                                            Glyph="&#xE7B8;"
                                        />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorPrimary}"
                                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                                            Text="{x:Bind ViewModel.ReviewPackageTypeText, Mode=OneWay}"
                                        />
                                    </StackPanel>
                                </Border>
                                <TextBox
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Background="{ThemeResource ControlFillColorDisabledBrush}"
                                    CornerRadius="0,0,8,8"
                                    IsHitTestVisible="False"
                                    IsReadOnly="True"
                                    Text="{x:Bind ViewModel.CurrentEntry.PackageTypeName, Mode=OneWay}"
                                />
                            </controls:UniformGrid>
                        </controls:UniformGrid>
                    </Border>
                </Grid>

                <!--  Navigation Bar for Single View  -->
                <CommandBar Grid.Row="2" Margin="0,12,0,0" DefaultLabelPosition="Right">
                    <AppBarButton
                        AutomationProperties.Name="{x:Bind ViewModel.ReviewPreviousEntryAccessibilityName, Mode=OneWay}"
                        Command="{x:Bind ViewModel.PreviousEntryCommand}"
                        Icon="Back"
                        IsEnabled="{x:Bind ViewModel.CanGoBack, Mode=OneWay}"
                        Label="{x:Bind ViewModel.ReviewPreviousLabelText, Mode=OneWay}"
                    />

                    <AppBarButton
                        AutomationProperties.Name="{x:Bind ViewModel.ReviewNextEntryAccessibilityName, Mode=OneWay}"
                        Command="{x:Bind ViewModel.NextEntryCommand}"
                        Icon="Forward"
                        IsEnabled="{x:Bind ViewModel.CanGoNext, Mode=OneWay}"
                        Label="{x:Bind ViewModel.ReviewNextLabelText, Mode=OneWay}"
                    />

                    <AppBarSeparator />

                    <AppBarButton
                        AutomationProperties.Name="{x:Bind ViewModel.ReviewSwitchToTableAccessibilityName, Mode=OneWay}"
                        Command="{x:Bind ViewModel.SwitchToTableViewCommand}"
                        Icon="ViewAll"
                        Label="{x:Bind ViewModel.ReviewTableViewLabelText, Mode=OneWay}"
                    />
                </CommandBar>
            </Grid>

            <!--  Table View (DataGrid)  -->
            <Grid Visibility="{x:Bind ViewModel.IsTableView, Mode=OneWay}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                >
                    <controls:DataGrid
                        x:Name="ReviewDataGrid"
                        AutoGenerateColumns="False"
                        AutomationProperties.Name="{x:Bind ViewModel.ReviewEntriesTableAccessibilityName, Mode=OneWay}"
                        CanUserSortColumns="True"
                        GridLinesVisibility="Horizontal"
                        HeadersVisibility="Column"
                        ItemsSource="{x:Bind ViewModel.Loads, Mode=OneWay}"
                        SelectionMode="Single"
                    >
                        <controls:DataGrid.CellStyle>
                            <Style TargetType="controls:DataGridCell">
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                            </Style>
                        </controls:DataGrid.CellStyle>
                        <controls:DataGrid.Columns>
                            <controls:DataGridTextColumn
                                Width="Auto"
                                Binding="{Binding LoadNumber}"
                                Header="{x:Bind ViewModel.ReviewColumnLoadNumberText, Mode=OneWay}"
                                IsReadOnly="True"
                            />
                            <controls:DataGridTextColumn
                                Width="*"
                                Binding="{Binding PartID}"
                                Header="{x:Bind ViewModel.ReviewColumnPartIdText, Mode=OneWay}"
                            />
                            <controls:DataGridTextColumn
                                Width="*"
                                Binding="{Binding WeightQuantity}"
                                Header="{x:Bind ViewModel.ReviewColumnWeightQtyText, Mode=OneWay}"
                            />
                            <controls:DataGridTextColumn
                                Width="Auto"
                                Binding="{Binding HeatLotNumber}"
                                Header="{x:Bind ViewModel.ReviewColumnHeatLotText, Mode=OneWay}"
                            />
                            <controls:DataGridTextColumn
                                Width="Auto"
                                Binding="{Binding InitialLocation}"
                                Header="{x:Bind ViewModel.ReviewColumnLocationText, Mode=OneWay}"
                            />
                            <controls:DataGridTextColumn
                                Width="*"
                                Binding="{Binding PoNumber, TargetNullValue='N/A'}"
                                Header="{x:Bind ViewModel.ReviewColumnPoNumberText, Mode=OneWay}"
                            />
                            <controls:DataGridTextColumn
                                Width="Auto"
                                Binding="{Binding PackagesPerLoad}"
                                Header="{x:Bind ViewModel.ReviewColumnPkgsText, Mode=OneWay}"
                            />
                            <controls:DataGridTextColumn
                                Width="Auto"
                                Binding="{Binding PackageTypeName}"
                                Header="{x:Bind ViewModel.ReviewColumnPkgTypeText, Mode=OneWay}"
                            />
                        </controls:DataGrid.Columns>
                    </controls:DataGrid>
                </Border>

                <!--  Navigation Bar for Table View  -->
                <CommandBar Grid.Row="1" Margin="0,16,0,0" DefaultLabelPosition="Right">
                    <AppBarButton
                        AutomationProperties.Name="{x:Bind ViewModel.ReviewSwitchToSingleAccessibilityName, Mode=OneWay}"
                        Command="{x:Bind ViewModel.SwitchToSingleViewCommand}"
                        Label="{x:Bind ViewModel.ReviewSingleViewLabelText, Mode=OneWay}"
                    >
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE8A9;" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar>
            </Grid>
        </Grid>

        <!--  Action Buttons  -->
        <Grid Grid.Row="2" Margin="0,16,0,0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="1"
                AutomationProperties.Name="{x:Bind ViewModel.ReviewAddAnotherAccessibilityName, Mode=OneWay}"
                Command="{x:Bind ViewModel.AddAnotherPartCommand}"
                ToolTipService.ToolTip="{x:Bind ViewModel.GetTooltip('Button.AddAnother'), Mode=OneWay}"
            >
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="16" Glyph="&#xE710;" />
                    <TextBlock Text="{x:Bind ViewModel.ReviewAddAnotherText, Mode=OneWay}" />
                </StackPanel>
            </Button>

            <Button
                Grid.Column="2"
                AutomationProperties.Name="{x:Bind ViewModel.ReviewSaveToDatabaseAccessibilityName, Mode=OneWay}"
                Command="{x:Bind ViewModel.SaveCommand}"
                Style="{StaticResource AccentButtonStyle}"
                ToolTipService.ToolTip="{x:Bind ViewModel.GetTooltip('Button.SaveAndGenerate'), Mode=OneWay}"
            >
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="16" Glyph="&#xE74E;" />
                    <TextBlock Text="{x:Bind ViewModel.ReviewSaveToDatabaseText, Mode=OneWay}" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
