<UserControl
    x:Class="MTM_Receiving_Application.Module_Receiving.Views.View_Receiving_ModeSelection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:MTM_Receiving_Application.Module_Receiving.ViewModels"
    mc:Ignorable="d"
>
    <Border
        Padding="20"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="8"
    >
        <Grid Padding="24" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel
                Grid.Column="0"
                Padding="12"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Spacing="12"
            >
                <!--  Guided Mode Column  -->
                <Button
                    MinWidth="240"
                    MinHeight="180"
                    Padding="20"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="{x:Bind ViewModel.GuidedAccessibilityName, Mode=OneWay}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Command="{x:Bind ViewModel.SelectGuidedModeCommand}"
                    CornerRadius="8"
                >
                    <StackPanel Spacing="12">
                        <FontIcon
                            FontSize="48"
                            Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                            Glyph="&#xE771;"
                        />
                        <TextBlock
                            HorizontalAlignment="Center"
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="{x:Bind ViewModel.GuidedTitleText, Mode=OneWay}"
                        />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{x:Bind ViewModel.GuidedDescriptionText, Mode=OneWay}"
                            TextAlignment="Center"
                            TextWrapping="Wrap"
                        />
                    </StackPanel>
                </Button>

                <!--  Guided Mode Checkbox  -->
                <CheckBox
                    HorizontalAlignment="Center"
                    Command="{x:Bind ViewModel.SetGuidedAsDefaultCommand}"
                    CommandParameter="{Binding IsChecked, RelativeSource={RelativeSource Self}}"
                    Content="{x:Bind ViewModel.SetAsDefaultText, Mode=OneWay}"
                    IsChecked="{x:Bind ViewModel.IsGuidedModeDefault, Mode=TwoWay}"
                    ToolTipService.ToolTip="{x:Bind ViewModel.GetTooltip('Button.QuickGuidedWizard'), Mode=OneWay}"
                />
            </StackPanel>

            <!--  Manual Mode Column  -->
            <StackPanel
                Grid.Column="1"
                Padding="12"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Spacing="12"
            >
                <Button
                    MinWidth="240"
                    MinHeight="180"
                    Padding="20"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="{x:Bind ViewModel.ManualAccessibilityName, Mode=OneWay}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Command="{x:Bind ViewModel.SelectManualModeCommand}"
                    CornerRadius="8"
                >
                    <StackPanel Spacing="12">
                        <FontIcon
                            FontSize="48"
                            Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                            Glyph="&#xE7F0;"
                        />
                        <TextBlock
                            HorizontalAlignment="Center"
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="{x:Bind ViewModel.ManualTitleText, Mode=OneWay}"
                        />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{x:Bind ViewModel.ManualDescriptionText, Mode=OneWay}"
                            TextAlignment="Center"
                            TextWrapping="Wrap"
                        />
                    </StackPanel>
                </Button>

                <!--  Manual Mode Checkbox  -->
                <CheckBox
                    HorizontalAlignment="Center"
                    Command="{x:Bind ViewModel.SetManualAsDefaultCommand}"
                    CommandParameter="{Binding IsChecked, RelativeSource={RelativeSource Self}}"
                    Content="{x:Bind ViewModel.SetAsDefaultText, Mode=OneWay}"
                    IsChecked="{x:Bind ViewModel.IsManualModeDefault, Mode=TwoWay}"
                    ToolTipService.ToolTip="{x:Bind ViewModel.GetTooltip('Button.QuickManualEntry'), Mode=OneWay}"
                />
            </StackPanel>

            <!--  Edit Mode Column  -->
            <StackPanel
                Grid.Column="2"
                Padding="12"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Spacing="12"
            >
                <Button
                    MinWidth="240"
                    MinHeight="180"
                    Padding="20"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="{x:Bind ViewModel.EditAccessibilityName, Mode=OneWay}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Command="{x:Bind ViewModel.SelectEditModeCommand}"
                    CornerRadius="8"
                >
                    <StackPanel Spacing="12">
                        <FontIcon
                            FontSize="48"
                            Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                            Glyph="&#xE70F;"
                        />
                        <TextBlock
                            HorizontalAlignment="Center"
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="{x:Bind ViewModel.EditTitleText, Mode=OneWay}"
                        />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{x:Bind ViewModel.EditDescriptionText, Mode=OneWay}"
                            TextAlignment="Center"
                            TextWrapping="Wrap"
                        />
                    </StackPanel>
                </Button>

                <!--  Edit Mode Checkbox  -->
                <CheckBox
                    HorizontalAlignment="Center"
                    Command="{x:Bind ViewModel.SetEditAsDefaultCommand}"
                    CommandParameter="{Binding IsChecked, RelativeSource={RelativeSource Self}}"
                    Content="{x:Bind ViewModel.SetAsDefaultText, Mode=OneWay}"
                    IsChecked="{x:Bind ViewModel.IsEditModeDefault, Mode=TwoWay}"
                    ToolTipService.ToolTip="{x:Bind ViewModel.GetTooltip('Button.QuickEditMode'), Mode=OneWay}"
                />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
