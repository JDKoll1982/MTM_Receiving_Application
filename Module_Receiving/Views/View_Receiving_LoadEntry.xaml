<UserControl
    x:Class="MTM_Receiving_Application.Module_Receiving.Views.View_Receiving_LoadEntry"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:converters="using:MTM_Receiving_Application.Module_Core.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    mc:Ignorable="d"
>
    <UserControl.Resources>
        <converters:Converter_BooleanToVisibility x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Padding="24">
        <Border
            Padding="32"
            HorizontalAlignment="Stretch"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
        >
            <StackPanel HorizontalAlignment="Stretch" Spacing="24">
                <StackPanel HorizontalAlignment="Center" FlowDirection="LeftToRight" Spacing="8">
                    <FontIcon
                        HorizontalAlignment="Center"
                        FontSize="48"
                        Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                        Glyph="&#xE7B8;"
                    />
                    <StackPanel HorizontalAlignment="Center" Spacing="2">
                        <TextBox
                            HorizontalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            IsReadOnly="True"
                            IsTabStop="False"
                            Text="{x:Bind ViewModel.SelectedPartId, Mode=OneWay}"
                            TextAlignment="Center"
                        />
                        <TextBox
                            HorizontalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="12"
                            FontWeight="Normal"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            IsReadOnly="True"
                            IsTabStop="False"
                            Text="{x:Bind ViewModel.SelectedPartDescription, Mode=OneWay}"
                            TextAlignment="Center"
                        />
                    </StackPanel>
                </StackPanel>

                <NumberBox
                    x:Name="NumberOfLoadsNumberBox"
                    MinWidth="240"
                    MaxWidth="480"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="{x:Bind ViewModel.NumberOfLoadsAccessibilityName, Mode=OneWay}"
                    Header="{x:Bind ViewModel.LoadEntryHeaderText, Mode=OneWay}"
                    LargeChange="10"
                    Maximum="99"
                    Minimum="1"
                    SmallChange="1"
                    SpinButtonPlacementMode="Inline"
                    Value="{x:Bind ViewModel.NumberOfLoads, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                />

                <ComboBox
                    MinWidth="240"
                    MaxWidth="480"
                    HorizontalAlignment="Stretch"
                    Header="{x:Bind ViewModel.LoadEntryLocationHeaderText, Mode=OneWay}"
                    ItemsSource="{x:Bind ViewModel.PresetLocations, Mode=OneWay}"
                    PlaceholderText="Select a preset mock location"
                    SelectedItem="{x:Bind ViewModel.Location, Mode=TwoWay}"
                    Visibility="{Binding ElementName=Root, Path=ViewModel.IsMockLocationMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                />

                <TextBox
                    MinWidth="240"
                    MaxWidth="480"
                    HorizontalAlignment="Stretch"
                    Header="{x:Bind ViewModel.LoadEntryLocationHeaderText, Mode=OneWay}"
                    LostFocus="LocationTextBox_LostFocus"
                    PlaceholderText="Enter receiving location"
                    Text="{x:Bind ViewModel.Location, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Visibility="{Binding ElementName=Root, Path=ViewModel.IsMockLocationMode, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"
                />

                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind ViewModel.LoadEntryLocationInstructionText, Mode=OneWay}"
                    TextAlignment="Center"
                />

                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind ViewModel.LoadEntryInstructionText, Mode=OneWay}"
                    TextAlignment="Center"
                />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
