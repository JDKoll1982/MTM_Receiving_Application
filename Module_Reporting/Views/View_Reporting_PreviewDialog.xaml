<ContentDialog
    x:Class="MTM_Receiving_Application.Module_Reporting.Views.View_Reporting_PreviewDialog"
    x:Name="DialogRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MTM_Receiving_Application.Module_Core.Models.Reporting"
    xmlns:previewModels="using:MTM_Receiving_Application.Module_Reporting.Models"
    mc:Ignorable="d"
    Title="Report Preview"
    CloseButtonText="Close"
    DefaultButton="Close"
    HorizontalContentAlignment="Center"
    VerticalContentAlignment="Center"
    HorizontalAlignment="Center"
    VerticalAlignment="Center">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMinWidth">900</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">1100</x:Double>
    </ContentDialog.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  MaxHeight="780">
        <StackPanel Spacing="16" Padding="20,18,20,20">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="{x:Bind ViewModel.PreviewSummaryTitle, Mode=OneWay}"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Review the included modules below. Uncheck any module before copying if you want it excluded from the final report."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               TextWrapping="WrapWholeWords"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Copy Report Summary"
                        Command="{x:Bind ViewModel.CopyEmailFormatCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        VerticalAlignment="Center"/>
            </Grid>

            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Padding="14">
                <StackPanel Spacing="10">
                    <TextBlock Text="Included Modules"
                               FontWeight="SemiBold"
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>

                    <ItemsControl ItemsSource="{x:Bind ViewModel.PreviewModuleCards, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="previewModels:Model_ReportingPreviewModuleCard">
                                <CheckBox Content="{x:Bind ModuleName}"
                                          IsChecked="{x:Bind IsIncluded, Mode=TwoWay}"
                                          Margin="0,0,16,0"
                                          VerticalAlignment="Center"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{x:Bind ViewModel.IncludedPreviewModuleCards, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="previewModels:Model_ReportingPreviewModuleCard">
                        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Background="White">
                            <StackPanel Spacing="0">
                                <Border Background="{x:Bind AccentBackgroundBrush}"
                                        Padding="12,10">
                                    <TextBlock Text="{x:Bind CardTitle}"
                                               Foreground="{x:Bind AccentForegroundBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               TextWrapping="WrapWholeWords"/>
                                </Border>

                                <StackPanel Padding="14"
                                            Spacing="14"
                                            Width="{Binding ViewModel.PreviewCardWidth, ElementName=DialogRoot}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Summary"
                                                   FontWeight="SemiBold"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>

                                        <Viewbox Stretch="Uniform"
                                                 StretchDirection="DownOnly"
                                                 HorizontalAlignment="Left"
                                                 Width="{Binding ViewModel.PreviewTableViewportWidth, ElementName=DialogRoot}">
                                            <Border BorderBrush="#D0DAE5"
                                                    BorderThickness="1"
                                                    Background="White"
                                                    CornerRadius="4"
                                                    Padding="12"
                                                    Width="{x:Bind SummaryTable.TableWidth}">
                                                <StackPanel>
                                                    <Border x:Name="SummaryHeaderRow"
                                                            Background="{x:Bind AccentBackgroundBrush}">
                                                        <ItemsControl ItemsSource="{x:Bind SummaryTable.Columns}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="models:Model_ReportSummaryColumn">
                                                                    <Border Width="{x:Bind Width}"
                                                                            Background="{Binding Background, ElementName=SummaryHeaderRow}"
                                                                            BorderBrush="#D0DAE5"
                                                                            BorderThickness="0,0,1,0">
                                                                        <TextBlock Text="{x:Bind Header}"
                                                                                   Foreground="White"
                                                                                   FontWeight="SemiBold"
                                                                                   Padding="12,10"
                                                                                   HorizontalAlignment="Center"
                                                                                   TextAlignment="Center"
                                                                                   TextWrapping="WrapWholeWords"/>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Border>

                                                    <ItemsControl ItemsSource="{x:Bind SummaryTable.Rows}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="models:Model_ReportSummaryTableRow">
                                                                <Border BorderBrush="#D6E7E3"
                                                                        BorderThickness="0,0,0,1"
                                                                        Background="#F7FBFA">
                                                                    <ItemsControl ItemsSource="{x:Bind Cells}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <StackPanel Orientation="Horizontal"/>
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate x:DataType="models:Model_ReportSummaryTableCell">
                                                                                <Border Width="{x:Bind Width}"
                                                                                        BorderBrush="#D6E7E3"
                                                                                        BorderThickness="0,0,1,0">
                                                                                    <TextBlock Text="{x:Bind Value}"
                                                                                               Padding="12,10"
                                                                                               HorizontalAlignment="Center"
                                                                                               TextAlignment="Center"
                                                                                               FontWeight="SemiBold"/>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </Viewbox>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Detailed Activity"
                                                   FontWeight="SemiBold"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>

                                        <TextBlock Text="{x:Bind Description}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="WrapWholeWords"/>

                                        <Viewbox Stretch="Uniform"
                                                 StretchDirection="DownOnly"
                                                 HorizontalAlignment="Left"
                                                 Width="{Binding ViewModel.PreviewTableViewportWidth, ElementName=DialogRoot}">
                                            <Border BorderBrush="#D0DAE5"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Background="White"
                                                    Padding="12"
                                                    Width="{x:Bind DetailTableWidth}">
                                                <StackPanel>
                                                    <Grid Background="{x:Bind AccentBackgroundBrush}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="170"/>
                                                            <ColumnDefinition Width="150"/>
                                                            <ColumnDefinition Width="90"/>
                                                            <ColumnDefinition Width="110"/>
                                                            <ColumnDefinition Width="170"/>
                                                            <ColumnDefinition Width="130"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0" Text="Quantity" Foreground="White" FontWeight="SemiBold" Padding="12,10" HorizontalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="Item" Foreground="White" FontWeight="SemiBold" Padding="12,10" HorizontalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="Reference" Foreground="White" FontWeight="SemiBold" Padding="12,10" HorizontalAlignment="Center"/>
                                                        <TextBlock Grid.Column="3" Text="Employee" Foreground="White" FontWeight="SemiBold" Padding="12,10" HorizontalAlignment="Center"/>
                                                        <TextBlock Grid.Column="4" Text="Date" Foreground="White" FontWeight="SemiBold" Padding="12,10" HorizontalAlignment="Center"/>
                                                        <TextBlock Grid.Column="5" Text="Location" Foreground="White" FontWeight="SemiBold" Padding="12,10" HorizontalAlignment="Center"/>
                                                        <TextBlock Grid.Column="6" Text="Packages/Loads" Foreground="White" FontWeight="SemiBold" Padding="12,10" HorizontalAlignment="Center"/>
                                                    </Grid>

                                                    <ItemsControl ItemsSource="{x:Bind Rows}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="models:Model_ReportRow">
                                                                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                                        BorderThickness="0,0,0,1"
                                                                        Background="#FAFCFF">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="80"/>
                                                                            <ColumnDefinition Width="170"/>
                                                                            <ColumnDefinition Width="150"/>
                                                                            <ColumnDefinition Width="90"/>
                                                                            <ColumnDefinition Width="110"/>
                                                                            <ColumnDefinition Width="170"/>
                                                                            <ColumnDefinition Width="130"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <TextBlock Grid.Column="0" Text="{x:Bind DisplayQuantity}" Padding="12,10" HorizontalAlignment="Center"/>
                                                                        <TextBlock Grid.Column="1" Text="{x:Bind DisplayPartOrDunnage}" Padding="12,10" HorizontalAlignment="Center" TextWrapping="WrapWholeWords"/>
                                                                        <TextBlock Grid.Column="2" Text="{x:Bind DisplayPo}" Padding="12,10" HorizontalAlignment="Center" TextWrapping="WrapWholeWords"/>
                                                                        <TextBlock Grid.Column="3" Text="{x:Bind EmployeeNumber}" Padding="12,10" HorizontalAlignment="Center"/>
                                                                        <TextBlock Grid.Column="4" Text="{x:Bind DisplayCreatedDate}" Padding="12,10" HorizontalAlignment="Center"/>
                                                                        <TextBlock Grid.Column="5" Text="{x:Bind DisplayLocation}" Padding="12,10" HorizontalAlignment="Center" TextWrapping="WrapWholeWords"/>
                                                                        <TextBlock Grid.Column="6" Text="{x:Bind DisplayLoadsOrSkids}" Padding="12,10" HorizontalAlignment="Center"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </Viewbox>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>