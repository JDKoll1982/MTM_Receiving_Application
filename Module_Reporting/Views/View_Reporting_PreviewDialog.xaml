<ContentDialog
    x:Class="MTM_Receiving_Application.Module_Reporting.Views.View_Reporting_PreviewDialog"
    x:Name="DialogRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MTM_Receiving_Application.Module_Core.Models.Reporting"
    xmlns:previewModels="using:MTM_Receiving_Application.Module_Reporting.Models"
    mc:Ignorable="d"
    Title="Report Preview"
    CloseButtonText="Close"
    DefaultButton="Close"
    HorizontalContentAlignment="Stretch"
    VerticalContentAlignment="Stretch"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
>
    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMinWidth">1320</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">2200</x:Double>
    </ContentDialog.Resources>

    <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Disabled"
        MaxHeight="900"
    >
        <StackPanel Spacing="16" Padding="20,18,20,20">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock
                        Text="{x:Bind ViewModel.PreviewSummaryTitle, Mode=OneWay}"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        FontWeight="SemiBold"
                    />
                    <TextBlock
                        Text="Review the included modules below. Uncheck any module before copying if you want it excluded from the final report."
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource BodyTextBlockStyle}"
                        TextWrapping="WrapWholeWords"
                    />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    Content="Copy Report Summary"
                    Command="{x:Bind ViewModel.CopyEmailFormatCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    VerticalAlignment="Center"
                />
            </Grid>

            <Border
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                Padding="14"
            >
                <StackPanel Spacing="10">
                    <TextBlock
                        Text="Included Modules"
                        FontWeight="SemiBold"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                    />

                    <ItemsControl ItemsSource="{x:Bind ViewModel.PreviewModuleCards, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="previewModels:Model_ReportingPreviewModuleCard">
                                <CheckBox
                                    Content="{x:Bind ModuleName}"
                                    IsChecked="{x:Bind IsIncluded, Mode=TwoWay}"
                                    Margin="0,0,16,0"
                                    VerticalAlignment="Center"
                                />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{x:Bind ViewModel.IncludedPreviewModuleCards, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="previewModels:Model_ReportingPreviewModuleCard">
                        <Border
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Background="White"
                        >
                            <StackPanel Spacing="0">
                                <Border Background="{x:Bind AccentBackgroundBrush}" Padding="12,10">
                                    <TextBlock
                                        Text="{x:Bind CardTitle}"
                                        Foreground="{x:Bind AccentForegroundBrush}"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        TextWrapping="WrapWholeWords"
                                    />
                                </Border>

                                <StackPanel Padding="14" Spacing="14" HorizontalAlignment="Stretch">
                                    <StackPanel Spacing="6">
                                        <TextBlock
                                            Text="Summary"
                                            FontWeight="SemiBold"
                                            Style="{StaticResource BodyStrongTextBlockStyle}"
                                        />

                                        <ScrollViewer
                                            HorizontalScrollBarVisibility="Auto"
                                            VerticalScrollBarVisibility="Disabled"
                                            HorizontalAlignment="Stretch"
                                        >
                                            <Border
                                                BorderBrush="#D0DAE5"
                                                BorderThickness="1"
                                                Background="White"
                                                CornerRadius="4"
                                                Padding="12"
                                                Width="{x:Bind SummaryTable.TableWidth}"
                                            >
                                                <StackPanel>
                                                    <Border
                                                        x:Name="SummaryHeaderRow"
                                                        Background="{x:Bind AccentBackgroundBrush}"
                                                    >
                                                        <ItemsControl ItemsSource="{x:Bind SummaryTable.Columns}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="models:Model_ReportSummaryColumn">
                                                                    <Border
                                                                        Width="{x:Bind Width}"
                                                                        Background="{Binding Background, ElementName=SummaryHeaderRow}"
                                                                        BorderBrush="#D0DAE5"
                                                                        BorderThickness="0,0,1,0"
                                                                    >
                                                                        <TextBlock
                                                                            Text="{x:Bind Header}"
                                                                            Foreground="White"
                                                                            FontWeight="SemiBold"
                                                                            Padding="12,10"
                                                                            HorizontalAlignment="Center"
                                                                            TextAlignment="Center"
                                                                            TextWrapping="WrapWholeWords"
                                                                        />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Border>

                                                    <ItemsControl ItemsSource="{x:Bind SummaryTable.Rows}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="models:Model_ReportSummaryTableRow">
                                                                <Border
                                                                    BorderBrush="#D6E7E3"
                                                                    BorderThickness="0,0,0,1"
                                                                    Background="#F7FBFA"
                                                                >
                                                                    <ItemsControl ItemsSource="{x:Bind Cells}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <StackPanel Orientation="Horizontal" />
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate x:DataType="models:Model_ReportSummaryTableCell">
                                                                                <Border
                                                                                    Width="{x:Bind Width}"
                                                                                    BorderBrush="#D6E7E3"
                                                                                    BorderThickness="0,0,1,0"
                                                                                >
                                                                                    <TextBlock
                                                                                        Text="{x:Bind Value}"
                                                                                        Padding="12,10"
                                                                                        HorizontalAlignment="Center"
                                                                                        TextAlignment="Center"
                                                                                        FontWeight="SemiBold"
                                                                                    />
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </ScrollViewer>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock
                                            Text="Detail Columns"
                                            FontWeight="SemiBold"
                                            Style="{StaticResource BodyStrongTextBlockStyle}"
                                        />

                                        <GridView
                                            ItemsSource="{x:Bind AvailableColumns}"
                                            SelectionMode="None"
                                            IsItemClickEnabled="False"
                                            IsSwipeEnabled="False"
                                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                            ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                            HorizontalAlignment="Stretch"
                                        >
                                            <GridView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4" />
                                                </ItemsPanelTemplate>
                                            </GridView.ItemsPanel>
                                            <GridView.ItemTemplate>
                                                <DataTemplate x:DataType="previewModels:Model_ReportingPreviewColumnOption">
                                                    <CheckBox
                                                        Content="{x:Bind Header}"
                                                        IsChecked="{x:Bind IsIncluded, Mode=TwoWay}"
                                                        Margin="0,0,12,8"
                                                    />
                                                </DataTemplate>
                                            </GridView.ItemTemplate>
                                        </GridView>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock
                                            Text="Detailed Activity"
                                            FontWeight="SemiBold"
                                            Style="{StaticResource BodyStrongTextBlockStyle}"
                                        />

                                        <TextBlock
                                            Text="{x:Bind Description}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextWrapping="WrapWholeWords"
                                        />

                                        <ScrollViewer
                                            HorizontalScrollBarVisibility="Auto"
                                            VerticalScrollBarVisibility="Disabled"
                                            HorizontalAlignment="Stretch"
                                        >
                                            <Border
                                                BorderBrush="#D0DAE5"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Background="White"
                                                Padding="12"
                                                Width="{x:Bind DetailTableWidth}"
                                            >
                                                <StackPanel>
                                                    <Border Background="{x:Bind AccentBackgroundBrush}">
                                                        <ItemsControl ItemsSource="{x:Bind IncludedColumns}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="previewModels:Model_ReportingPreviewColumnOption">
                                                                    <Border Width="{x:Bind Width}" BorderBrush="#D0DAE5" BorderThickness="0,0,1,0">
                                                                        <TextBlock
                                                                            Text="{x:Bind Header}"
                                                                            Foreground="White"
                                                                            FontWeight="SemiBold"
                                                                            Padding="12,10"
                                                                            HorizontalAlignment="Center"
                                                                            TextAlignment="Center"
                                                                            TextWrapping="WrapWholeWords"
                                                                        />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Border>

                                                    <ItemsControl ItemsSource="{x:Bind PreviewRows}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="previewModels:Model_ReportingPreviewRow">
                                                                <Border
                                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                                    BorderThickness="0,0,0,1"
                                                                    Background="#FAFCFF"
                                                                >
                                                                    <ItemsControl ItemsSource="{x:Bind Cells}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <StackPanel Orientation="Horizontal" />
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate x:DataType="previewModels:Model_ReportingPreviewCell">
                                                                                <Border Width="{x:Bind Width}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
                                                                                    <TextBlock
                                                                                        Text="{x:Bind Value}"
                                                                                        Padding="12,10"
                                                                                        TextAlignment="{x:Bind TextAlignment}"
                                                                                        TextWrapping="WrapWholeWords"
                                                                                    />
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </ScrollViewer>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
