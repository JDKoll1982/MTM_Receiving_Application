<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="MTM_Receiving_Application.Module_Core.Dialogs.Dialog_FuzzySearchPicker"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MTM_Receiving_Application.Module_Core.Models.InforVisual"
    xmlns:converters="using:MTM_Receiving_Application.Module_Core.Converters"
    mc:Ignorable="d"
    PrimaryButtonText="Select"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="False"
    MinWidth="480"
>
    <ContentDialog.Resources>
        <converters:Converter_EmptyStringToVisibility x:Key="EmptyStringToVisibilityConverter" />
    </ContentDialog.Resources>

    <StackPanel Spacing="12" MinWidth="440" MaxWidth="600">
        <!-- Optional subtitle / context hint -->
        <TextBlock
            x:Name="SubtitleText"
            Style="{StaticResource BodyTextBlockStyle}"
            Opacity="0.7"
            TextWrapping="Wrap"
            Visibility="Collapsed"
        />

        <!-- Live-filter box (client-side, no round-trip) -->
        <TextBox
            x:Name="FilterBox"
            PlaceholderText="Type to narrow results…"
            TextChanged="FilterBox_TextChanged"
        />

        <!-- Results list -->
        <Border
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4"
            MaxHeight="340"
        >
            <ListView
                x:Name="ResultsListView"
                SelectionMode="Single"
                SelectionChanged="ResultsListView_SelectionChanged"
                DoubleTapped="ResultsListView_DoubleTapped"
            >
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Model_FuzzySearchResult">
                        <StackPanel Spacing="2" Padding="4,6">
                            <TextBlock
                                Text="{x:Bind Label}"
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                            />
                            <TextBlock
                                Text="{x:Bind Detail}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Visibility="{x:Bind Detail, Converter={StaticResource EmptyStringToVisibilityConverter}}"
                            />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <!-- Result count -->
        <TextBlock
            x:Name="ResultCountText"
            Style="{StaticResource CaptionTextBlockStyle}"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
        />
    </StackPanel>
</ContentDialog>
